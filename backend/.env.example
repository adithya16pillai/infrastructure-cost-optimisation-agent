# Set to "true" to run entirely on deterministic mock data (no AWS / GCP /
# Anthropic credentials needed).
MOCK_CLOUD=true

# Default cloud provider when an analysis request omits one ("aws" | "gcp").
# The dashboard lets you pick per run; this is just the fallback.
CLOUD_PROVIDER=aws

# Anthropic Claude API key. If unset, the validator falls back to a deterministic
# heuristic so the app still runs end-to-end with no credentials.
ANTHROPIC_API_KEY=sk-ant-...
VALIDATOR_MODEL=claude-sonnet-4-6

# Real AWS mode (only used when MOCK_CLOUD=false). Standard boto3 credential
# resolution applies (env vars, shared config, instance role).
AWS_REGION=us-east-1

# Real GCP mode is not yet implemented (RealGcpClient is a stub). These settings
# are read for when it is wired up; run with MOCK_CLOUD=true for now.
GCP_REGION=us-central1
GCP_PROJECT_ID=

# Storage
DATABASE_URL=sqlite:///./app.db

# Logging
LOG_LEVEL=INFO

# Detector thresholds (used from PRD 03 onward)
IDLE_CPU_PERCENT_THRESHOLD=5.0
IDLE_LOOKBACK_DAYS=14
SNAPSHOT_AGE_DAYS_THRESHOLD=180
