# Set to "true" to run entirely on deterministic mock data (no AWS / Anthropic needed).
MOCK_AWS=true

# Anthropic Claude API key. If unset, the validator falls back to a deterministic
# heuristic so the app still runs end-to-end with no credentials.
ANTHROPIC_API_KEY=sk-ant-...
VALIDATOR_MODEL=claude-sonnet-4-6

# Real AWS mode (only used when MOCK_AWS=false). Standard boto3 credential
# resolution applies (env vars, shared config, instance role).
AWS_REGION=us-east-1

# Storage
DATABASE_URL=sqlite:///./app.db

# Logging
LOG_LEVEL=INFO

# Detector thresholds (used from PRD 03 onward)
IDLE_CPU_PERCENT_THRESHOLD=5.0
IDLE_LOOKBACK_DAYS=14
SNAPSHOT_AGE_DAYS_THRESHOLD=180
